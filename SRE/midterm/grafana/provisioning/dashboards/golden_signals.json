{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Four Golden Signals + SLO compliance for the Analytical Platform (Node.js + MongoDB)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "SLO Overview", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Availability SLO: 99.5% of requests must return non-5xx. Green = SLO met.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99   },
              { "color": "green",  "value": 99.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(http_requests_total{job=\"analytical-platform\",status_code!~\"5..\"}[30m])) / sum(rate(http_requests_total{job=\"analytical-platform\"}[30m]))) * 100",
          "legendFormat": "Availability %",
          "refId": "A"
        }
      ],
      "title": "Availability SLO (target ≥ 99.5%)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latency SLO: 95th-percentile response time must be ≤ 500 ms. Green = SLO met.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 1.0  }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 102,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"analytical-platform\"}[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "title": "Latency SLO – p95 (target ≤ 500 ms)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current 5xx error rate over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 5.0  }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 103,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(http_requests_total{job=\"analytical-platform\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"analytical-platform\"}[5m]))) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "title": "Current Error Rate %",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Backend process uptime in seconds.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 104,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_uptime_seconds{job=\"analytical-platform\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "title": "Backend Uptime",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "id": 200, "title": "Traffic", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "HTTP request throughput in requests per second, broken down by route.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 201,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"analytical-platform\"}[1m])) by (route)",
          "legendFormat": "{{ route }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Route (req/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Request throughput broken down by HTTP status code.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 202,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"analytical-platform\"}[1m])) by (status_code)",
          "legendFormat": "HTTP {{ status_code }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Status Code (req/s)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "id": 300, "title": "Latency", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p50 / p95 / p99 HTTP request duration. SLO: p95 ≤ 500 ms.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 1.0  }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 301,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"analytical-platform\"}[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"analytical-platform\"}[1m])) by (le))",
          "legendFormat": "p95 (SLO ≤ 500 ms)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"analytical-platform\"}[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Request Latency – p50 / p95 / p99",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Node.js event-loop lag – high values indicate the event loop is blocked.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 302,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_seconds{job=\"analytical-platform\"}",
          "legendFormat": "event-loop lag",
          "refId": "A"
        }
      ],
      "title": "Node.js Event-Loop Lag",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "id": 400, "title": "Errors", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "HTTP 5xx error rate as a percentage of total requests. SLO: < 0.5%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 5.0  }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 401,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(http_requests_total{job=\"analytical-platform\",status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"analytical-platform\"}[1m]))) * 100",
          "legendFormat": "5xx error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(http_requests_total{job=\"analytical-platform\",status_code=~\"4..\"}[1m])) / sum(rate(http_requests_total{job=\"analytical-platform\"}[1m]))) * 100",
          "legendFormat": "4xx error rate",
          "refId": "B"
        }
      ],
      "title": "API Error Rate % (SLO: 5xx < 0.5%)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Raw count of HTTP 5xx errors per second.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 12 },
          "unit": "reqps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 402,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"analytical-platform\",status_code=~\"5..\"}[1m])) by (route)",
          "legendFormat": "5xx – {{ route }}",
          "refId": "A"
        }
      ],
      "title": "5xx Errors by Route (req/s)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }, "id": 500, "title": "Saturation", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Node.js process heap memory usage.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 501,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_used_bytes{job=\"analytical-platform\"}",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_total_bytes{job=\"analytical-platform\"}",
          "legendFormat": "heap total",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes{job=\"analytical-platform\"}",
          "legendFormat": "RSS",
          "refId": "C"
        }
      ],
      "title": "Node.js Memory Usage",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Host CPU and memory saturation via Node Exporter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red",    "value": 0.90 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 502,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "CPU utilisation",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "Memory utilisation",
          "refId": "B"
        }
      ],
      "title": "Host CPU & Memory Saturation",
      "type": "timeseries"
    }

  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["sre", "midterm", "golden-signals", "analytical-platform"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Analytical Platform – Golden Signals & SLO",
  "uid": "analytical-platform-slo",
  "version": 1
}
