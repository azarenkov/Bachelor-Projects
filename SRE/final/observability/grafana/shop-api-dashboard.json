{
  "title": "Shop API — SLO dashboard",
  "uid": "shop-api-slo",
  "tags": ["sre", "capstone"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(shop_api_http_requests_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 1 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx, 5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "shop_api:error_rate5m", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 latency /work",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(shop_api_http_request_duration_seconds_bucket{route=\"/work\"}[5m])) by (le))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "shop-api replicas",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "count(shop_api_inflight_requests)", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests per second (per route)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(shop_api_http_requests_total[1m])) by (route)", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(shop_api_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(shop_api_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(shop_api_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU per pod",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"shop\", pod=~\"shop-api-.*\", container=\"shop-api\"}[1m])) by (pod)", "legendFormat": "{{pod}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "In-flight HTTP requests",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(shop_api_inflight_requests)", "refId": "A" }
      ]
    }
  ]
}
